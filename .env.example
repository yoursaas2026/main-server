# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/your_database"

# Server
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="66783315842-fu8rf501o6gvm32boj87stt45omsreuq.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/developer/auth/google/callback"

# Microsoft OAuth
MICROSOFT_CLIENT_ID="58aec5eb-b567-432d-b730-d0f6329c39d0"
MICROSOFT_CLIENT_SECRET="2cf320aa-d3d5-49fe-9482-0c741b111156"
MICROSOFT_CALLBACK_URL="http://localhost:3000/api/developer/auth/microsoft/callback"

# Apple OAuth
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_KEY_ID="your-apple-key-id"
APPLE_PRIVATE_KEY="your-apple-private-key"
APPLE_CALLBACK_URL="http://localhost:3000/api/developer/auth/apple/callback"

# Brevo Email Service
BREVO_API_KEY="your-brevo-api-key"
BREVO_SENDER_EMAIL="noreply@yoursaas.com"
BREVO_SENDER_NAME="YourSaaS"
# Optional: Brevo contacts list ID for footer newsletter signups
BREVO_NEWSLETTER_LIST_ID=""

# Frontend (local)
DEVELOPER_PORTAL_URL="http://localhost:3001"
USER_PORTAL_URL="http://localhost:3002"
ADMIN_PORTAL_URL="http://localhost:3003"
# Include every portal origin that calls this API (exact scheme + host, comma-separated).
# Production example:
# DEVELOPER_PORTAL_URL="https://dev.yoursaas.in"
# USER_PORTAL_URL="https://yoursaas.in"
# ADMIN_PORTAL_URL="https://admin.yoursaas.in"
# CORS_ORIGIN="https://dev.yoursaas.in,https://yoursaas.in,https://admin.yoursaas.in,https://server.yoursaas.in"
CORS_ORIGIN="http://localhost:3001,http://localhost:3000,http://localhost:3002,http://localhost:3003"

# GetStream Chat — create an app at https://dashboard.getstream.io/
STREAM_API_KEY=""
STREAM_API_SECRET=""
# Public URL of this API (for absolute avatar URLs pushed to Stream). No trailing slash.
API_PUBLIC_ORIGIN="http://localhost:3000"
# Production: API_PUBLIC_ORIGIN="https://server.yoursaas.in"

# Razorpay — developer plan Checkout (orders) and webhooks
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# RazorpayX bank validation: current account number charged for validation (live; see Razorpay docs — not available in test mode)
RAZORPAYX_SOURCE_ACCOUNT_NUMBER=""

# Marketplace contracts — platform % of escrow after completion (integer 20 = 20% to YourSaaS, 80% to developer). Tier INR prices are on each listing.
CONTRACT_PLATFORM_COMMISSION_PERCENT=20
CONTRACT_CLIENT_DECISION_DAYS=14
# Auto-complete submitted contracts when client is silent (background job interval ms, default 5 min)
CONTRACT_AUTO_COMPLETE_INTERVAL_MS=300000
# When true, after completion/dispute resolution: Razorpay refunds to client + RazorpayX payout to validated developer bank
CONTRACT_AUTO_SETTLEMENT_ENABLED=false
